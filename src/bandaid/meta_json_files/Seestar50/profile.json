        "obs_time": "@DATE-OBS",
        "site_lat": "@SITELAT",
        "site_lon": "@SITELONG",
        "site_elev": "@SITEELEV",
        "observer": "@obscode",
        "_filter": "not for unprocessed files",
        "block_filter": "@FILTER",
        "exposure": "@EXPTIME",
        "tel_manufac": "!CREATOR index 0",
        "tel_model": "@INSTRUME",
        "tel_firmware": "@PROGRAM",
        "adc_depth": 12,
        "largest_usable_adu_value": 50000,
        "egain": 0.3116,
        "bayerpat": "@BAYERPAT",
