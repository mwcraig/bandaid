{
    "_note": "This is the basic adj json file for the Origin",
    "obs_time": "!StackedInfo.dateTime refmtDate %m-%d-%yB%H_%M_%S",
    "site_lat": "@StackedInfo.gps.latitude",
    "site_lon": "@StackedInfo.gps.longitude",
    "site_elev": "@StackedInfo.gps.altitude",
    "observer": "@personal.obscode",
    "_filter": "not for unprocessed files",
    "block_filter" : "UV+IR",  
    "exposure": "@StackedInfo.captureParams.exposure",
    "tel_manufac": "Celestron",
    "tel_model": "!CREATOR index 0",
    "tel_firmware" : "!CREATOR index 1",
    "adc_depth" : "@StackedInfo.captureParams.bitDepth",
    "largest_usable_adu_value" : 50000,
    "system_gain" : 0.5,
    "bayerpat": "BGGR", 
    "pixscale" : 1.48,
    "epoch" : "J2000",
    "refframe" : "ICRS",
    "dec": "@StackedInfo.celestial.secondAngle.degrees",
    "ra": "@StackedInfo.celestial.firstAngle.degrees",
    "fov_rad" : 0.75,
    "_telescope_probe" : "from fits",
    "roworder": "top-down",
    "ybayroff": 0
}
